PORT=3001
HOST=0.0.0.0
MONGODB_URI=mongodb://localhost:27017/weow
CLIENT_URL=http://localhost:5173
CLIENT_PORT=5173

ADMIN_API_KEY=change-me-admin-key

# Admin Panel（/admin 登入）
ADMIN_PANEL_USERNAME=admin
ADMIN_PANEL_PASSWORD=change-me-panel-password
ADMIN_PANEL_JWT_SECRET=change-me-admin-panel-jwt-secret

GAME_JWT_SECRET=change-me-game-jwt-secret
GAME_QR_SECRET=change-me-game-qr-secret

# Email validation (deep-email-validator)
EMAIL_VALIDATE_TIMEOUT_MS=8000
EMAIL_VALIDATE_SMTP=false

# Production 範例（Cloudflare Flexible + Apache reverse proxy）：
# NODE_ENV=production
# HOST=127.0.0.1
# CLIENT_URL=https://meow.ice-solution.hk
